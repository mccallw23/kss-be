# Stripe API keys (from dashboard.stripe.com/apikeys)
# Use sk_test_* for testing, sk_live_* for production
STRIPE_SECRET_KEY=sk_test_...

# Stripe publishable key (NOT secret, used in frontend checkout.html)
# This goes in fe/checkout.html and fe/success.html, not here
# STRIPE_PUBLISHABLE_KEY=pk_test_... or pk_live_...

# Webhook signing secret (from dashboard.stripe.com/webhooks after creating endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# Your landing page URL (for CORS and success redirects)
LANDING_PAGE_URL=https://kitchensinksender.com

# Stripe Price IDs (from dashboard.stripe.com/products)
# Create each product and copy the price_ ID
PRICE_SINGLE=price_...
PRICE_MONTHLY=price_...
PRICE_QUARTERLY=price_...
PRICE_BIANNUAL=price_...
PRICE_KIT=price_...
